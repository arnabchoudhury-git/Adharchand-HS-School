{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "uid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "uid"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global settings for the school application portal",
      "type": "object",
      "properties": {
        "open": { "type": "boolean" },
        "updatedAt": { "type": "string" },
        "updatedBy": { "type": "string" }
      },
      "required": ["open"]
    },
    "Admission": {
      "title": "Admission",
      "description": "Student admission application form data",
      "type": "object",
      "properties": {
        "studentName": { "type": "string" },
        "fatherName": { "type": "string" },
        "motherName": { "type": "string" },
        "gradeSelection": { "type": "string" },
        "dob": { "type": "string" },
        "gender": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "aadhaarNumber": { "type": "string" },
        "penNumber": { "type": "string" },
        "apaarNumber": { "type": "string" },
        "caste": { "type": "string" },
        "religion": { "type": "string" },
        "currentAddress": { "type": "string" },
        "permanentAddress": { "type": "string" },
        "previousSchool": { "type": "string" },
        "leavingCause": { "type": "string" },
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentName", "userId", "status", "submittedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "admissions/{admissionId}": {
      "schema": "Admission",
      "description": "Admission form submissions"
    },
    "settings/{settingId}": {
      "schema": "Settings",
      "description": "System operational and state configurations"
    }
  }
}
